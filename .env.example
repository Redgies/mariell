# ============================================================
# Mariell — Variables d'environnement
# ------------------------------------------------------------
# Copie ce fichier en `.env` (ignoré par git) et remplis les valeurs.
# Sur Vercel, configure les mêmes variables dans
#   Project Settings → Environment Variables
# (Production + Preview + Development).
#
# Légende :
#   🆕 spécifique outil 1
#   🔁 partagé avec les futurs outils 2 / 3
#   ⚙️ auto-injecté par Vercel quand l'intégration est branchée
# ============================================================


# ----------------------------------------------------------------
# 🌐 URL publique du site
# ----------------------------------------------------------------
# Utilisée dans les emails Brevo (CTA "Retour au Lab"), les liens
# absolus, et le contexte serveur. En dev local : http://localhost:3000
NUXT_PUBLIC_SITE_URL=https://mariell.fr


# ----------------------------------------------------------------
# 🛡️ Cloudflare Turnstile  🔁
# ----------------------------------------------------------------
# Crée un site sur https://dash.cloudflare.com/?to=/:account/turnstile
# Mode "Invisible". Ajoute `mariell.fr` ET `localhost` aux domaines
# autorisés pour pouvoir tester en dev.
NUXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA__remplace_moi__
NUXT_TURNSTILE_SECRET_KEY=0x4AAAAAAA__remplace_moi__


# ----------------------------------------------------------------
# ✉️ Brevo (transactional email)  🔁
# ----------------------------------------------------------------
# 1. Vérifie l'expéditeur `bonjour@mariell.fr` (DNS SPF + DKIM)
# 2. Génère une API key dans Account → SMTP & API
# 3. Adresses destinataires côté Mariell (peuvent être identiques)
BREVO_API_KEY=xkeysib-__remplace_moi__
BREVO_SENDER_EMAIL=bonjour@mariell.fr
BREVO_NOTIF_RECIPIENT=__email_du_gerant__@mariell.fr
BREVO_ALERT_RECIPIENT=__email_du_gerant__@mariell.fr

# Templates Brevo spécifiques outil 1  🆕
# Crée 2 templates dans Brevo (HTML fourni par le brief), récupère les IDs
BREVO_TEMPLATE_ID_STAGE_NOTIF_INTERNE=__id_numerique__
BREVO_TEMPLATE_ID_STAGE_CONFIRMATION_PROSPECT=__id_numerique__


# ----------------------------------------------------------------
# 🗂️ Jarvi (CRM)  🔁
# ----------------------------------------------------------------
# Génère une API key dans les settings Jarvi
JARVI_API_KEY=__remplace_moi__
JARVI_API_BASE_URL=https://functions.prod.jarvi.tech/v1/public-api/rest/v2

# UUIDs des statuts Project — UN PAR OUTIL  🆕
# Crée d'abord dans Jarvi 3 statuts Project distincts (ou 3 status groups si tu
# préfères les regrouper). Récupère l'UUID de chacun via l'URL Jarvi UI.
# C'est ce statut qui sera assigné aux projects créés par chaque outil.
JARVI_STATUS_ID_STAGE_ALTERNANCE=__uuid_statut_outil_1__
JARVI_STATUS_ID_PLAN_SOURCING=__uuid_statut_outil_2__
JARVI_STATUS_ID_EVALUATION_ATTRACTIVITE=__uuid_statut_outil_3__

# Custom field Project "Type de demande Lab" (multiplechoice)
# Doit avoir au minimum les valeurs : Stage/Alternance, Plan de sourcing, Évaluation attractivité
# (les valeurs sont passées en string littérale par le code, pas via UUID)
JARVI_FIELD_ID_TYPE_DEMANDE_LAB=__uuid_du_custom_field__

# UUIDs des statuts Project considérés "actifs" pour le check anti-doublon outil 1
# Sépare par virgule. Inclus tous les statuts dans lesquels un project peut être
# en cours de traitement (ex. "Reçue" + "En traitement").
JARVI_LAB_ACTIVE_STATUS_IDS=__uuid_actif_1__,__uuid_actif_2__

# UUIDs des statuts Company qui correspondent à "Client / ancien client"
# Séparés par virgule. Peut rester vide au départ — fail-soft :
# toutes les Companies existantes apparaîtront alors comme "Contact connu".
JARVI_CLIENT_STATUS_IDS=


# ----------------------------------------------------------------
# 💾 Upstash Redis (rate limiting + persistance plans)  🔁  ⚙️
# ----------------------------------------------------------------
# Vercel dashboard → Storage → Create Database → Upstash Redis
# → Connect to project. Les 2 variables ci-dessous sont alors
# auto-injectées en Production + Preview.
# En dev local : copie-colle les valeurs depuis le dashboard Upstash.
KV_REST_API_URL=https://__projet__.upstash.io
KV_REST_API_TOKEN=__remplace_moi__


# ================================================================
#  OUTIL 2 — Plan de sourcing LinkedIn
# ================================================================

# ----------------------------------------------------------------
# 🤖 Anthropic Claude API (génération du plan)  🆕
# ----------------------------------------------------------------
# Génère une clé sur https://console.anthropic.com/settings/keys
# Modèle utilisé : claude-haiku-4-5 (alias non-daté, suit les minor updates)
ANTHROPIC_API_KEY=sk-ant-__remplace_moi__

# ----------------------------------------------------------------
# 📅 Calendly  🔁 (partagé outils 2 et 3 plus tard)
# ----------------------------------------------------------------
NUXT_PUBLIC_CALENDLY_URL=https://calendly.com/chez-mariell/30min

# ----------------------------------------------------------------
# ✉️ Brevo — Templates outil 2  🆕
# ----------------------------------------------------------------
# Crée 4 templates dans Brevo (HTML fourni dans docs/outil-2/brevo-templates/)
# Récupère leurs IDs numériques.
BREVO_TEMPLATE_ID_PLAN_SOURCING_NOTIF_INTERNE=__id_numerique__
BREVO_TEMPLATE_ID_PLAN_SOURCING_LIVRAISON_PROSPECT=__id_numerique__
BREVO_TEMPLATE_ID_PLAN_SOURCING_DEFERRED_INTERNE=__id_numerique__
BREVO_TEMPLATE_ID_PLAN_SOURCING_DEFERRED_PROSPECT=__id_numerique__


# ================================================================
#  OUTIL 3 — Évaluation d'attractivité
# ================================================================
# Anthropic et Calendly sont déjà configurés ci-dessus (mutualisés).
# Les 5 prompts (V9 + F1 + F2 + F3 + F4) sont chargés depuis
# server/prompts/outil-3/*.md au boot — pas de var d'env.

# ----------------------------------------------------------------
# ✉️ Brevo — Templates outil 3  🆕
# ----------------------------------------------------------------
# 4 templates à créer (HTML dans docs/outil-3/brevo-templates/)
BREVO_TEMPLATE_ID_EVALUATION_ATTRACTIVITE_NOTIF_INTERNE_LIVREE=__id_numerique__
BREVO_TEMPLATE_ID_EVALUATION_ATTRACTIVITE_NOTIF_INTERNE_DIFFEREE=__id_numerique__
BREVO_TEMPLATE_ID_EVALUATION_ATTRACTIVITE_CONFIRMATION_PROSPECT=__id_numerique__
BREVO_TEMPLATE_ID_EVALUATION_ATTRACTIVITE_SUIVI_PROSPECT=__id_numerique__

# ----------------------------------------------------------------
# 🗂️ Jarvi — Custom field value pour outil 2  🆕
# ----------------------------------------------------------------
# UUID de la valeur "Plan de sourcing" dans le custom field
# "Type de demande Lab". Si tu ne l'as pas encore récupérée :
# voir docs/outil-1/INSTRUCTIONS-DEV-outil-1.md (même process).
# Optionnelle pour l'instant — la valeur "Plan de sourcing"
# est passée en string littéral à l'API Jarvi (cohérent outil 1).
